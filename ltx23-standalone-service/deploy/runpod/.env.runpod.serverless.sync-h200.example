# Runpod account
RUNPOD_API_KEY=rp_xxx

# Optional: private GHCR image pull credential id in Runpod
# RUNPOD_CONTAINER_REGISTRY_AUTH_ID=clzdaifot0001l90809257ynb

# Build image tag to deploy
RUNPOD_IMAGE=ghcr.io/linkspriteai/ltx23-sync:latest

# Template + endpoint identity
RUNPOD_TEMPLATE_NAME=ltx23-sync-serverless-h200
RUNPOD_ENDPOINT_NAME=ltx23-sync-serverless-h200

# Optional explicit IDs to update existing resources
# RUNPOD_TEMPLATE_ID=
# RUNPOD_ENDPOINT_ID=

# Worker profile
RUNPOD_GPU_TYPE=NVIDIA H200
RUNPOD_GPU_COUNT=1
RUNPOD_WORKERS_MIN=0
RUNPOD_WORKERS_MAX=1
RUNPOD_IDLE_TIMEOUT=5
RUNPOD_EXECUTION_TIMEOUT_MS=1800000
RUNPOD_SCALER_TYPE=QUEUE_DELAY
RUNPOD_SCALER_VALUE=1
RUNPOD_FLASHBOOT=true
RUNPOD_ALLOWED_CUDA=13.0
RUNPOD_MIN_CUDA_VERSION=13.0
RUNPOD_CONTAINER_DISK_GB=160
RUNPOD_VOLUME_GB=500
RUNPOD_VOLUME_MOUNT_PATH=/workspace
RUNPOD_TEMPLATE_CATEGORY=NVIDIA

# Optional placement
# RUNPOD_DATA_CENTER_IDS=US-KS-2
# RUNPOD_NETWORK_VOLUME_ID=

# LTX runtime env
SERVICE_API_KEY=ltx23-internal-key
HF_TOKEN=hf_xxx
DATA_DIR=/workspace/data
FRAME_COUNT_MAX=97

# Sync-only split mode
LTX_ENABLE_STANDARD_AV=false
LTX_ENABLE_SYNC_AV=true
LTX_PRELOAD_ON_START=true
LTX_DEFAULT_MODEL_VARIANT=distilled

# Sync model stack (HF parity path)
LTX_MODEL_REPO=Lightricks/LTX-2.3
LTX_MODEL_CHECKPOINT_REPO=linoyts/ltx-2.3-22b-fused-union-control
LTX_MODEL_CHECKPOINT_DISTILLED=ltx-2.3-22b-fused-union-control.safetensors
LTX_MODEL_CHECKPOINT_FULL=ltx-2.3-22b-fused-union-control.safetensors
LTX_MODEL_DISTILLED_LORA=ltx-2.3-22b-distilled-lora-384.safetensors
LTX_MODEL_SPATIAL_UPSAMPLER=ltx-2.3-spatial-upscaler-x2-1.1.safetensors
LTX_DISTILLED_USE_FP8_CAST=true
LTX_FULL_USE_FP8_CAST=false
LTX_SYNC_FORCE_DISTILLED=true
LTX_SYNC_ASSUME_FUSED_CHECKPOINT=true
LTX_SYNC_PRE_HOPPER_FALLBACK_ENABLED=false
LTX_SYNC_IC_LORA_REPO=Lightricks/LTX-2.3-22b-IC-LoRA-Union-Control
LTX_SYNC_IC_LORA_FILENAME=ltx-2.3-22b-ic-lora-union-control-ref0.5.safetensors
LTX_SYNC_REFERENCE_DOWNSCALE_FACTOR=2
LTX_SYNC_VIDEO_PREPROCESS_MODE=pose_dwpose

