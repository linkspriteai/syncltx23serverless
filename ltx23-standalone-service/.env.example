SERVICE_NAME=ltx23-standalone-service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080
SERVICE_API_KEY=replace-me

DATA_DIR=./data
UPLOAD_MAX_MB=20
FRAME_COUNT_MAX=257
LTX_ENABLE_STANDARD_AV=true
LTX_ENABLE_SYNC_AV=true

HF_TOKEN=
LTX_MODEL_REPO=Lightricks/LTX-2.3
LTX_MODEL_CHECKPOINT_REPO=Lightricks/LTX-2.3-fp8
LTX_GEMMA_REPO=google/gemma-3-12b-it-qat-q4_0-unquantized

LTX_MODEL_CHECKPOINT_DISTILLED=ltx-2.3-22b-distilled-fp8.safetensors
LTX_MODEL_CHECKPOINT_FULL=ltx-2.3-22b-dev-fp8.safetensors
LTX_MODEL_DISTILLED_LORA=ltx-2.3-22b-distilled-lora-384.safetensors
LTX_MODEL_SPATIAL_UPSAMPLER=ltx-2.3-spatial-upscaler-x2-1.1.safetensors

LTX_DEFAULT_MODEL_VARIANT=distilled
LTX_DISTILLED_USE_FP8_CAST=false
LTX_FULL_USE_FP8_CAST=false
LTX_FULL_NUM_INFERENCE_STEPS=30

LTX_PRELOAD_ON_START=true
LTX_LOCAL_CHECKPOINTS_DIR=/data/models/checkpoints
LTX_SYNC_FORCE_DISTILLED=true
LTX_SYNC_ASSUME_FUSED_CHECKPOINT=true
LTX_SYNC_PRE_HOPPER_FALLBACK_ENABLED=true
LTX_SYNC_REFERENCE_DOWNSCALE_FACTOR=2
LTX_SYNC_VIDEO_PREPROCESS_MODE=pose_dwpose
